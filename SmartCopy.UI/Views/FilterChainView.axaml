<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             xmlns:views="clr-namespace:SmartCopy.UI.Views"
             x:Class="SmartCopy.UI.Views.FilterChainView"
             x:DataType="vm:FilterChainViewModel">
    <Border Background="#252526" BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="6" Padding="10">
        <DockPanel>
            <!-- Header pinned to the top -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                <TextBlock Grid.Column="0" Text="FILTERS" FontWeight="SemiBold" Foreground="#4facfe" VerticalAlignment="Center" />
                <ToggleButton Grid.Column="1" Content="👁"
                              ToolTip.Tip="Toggle visibility of excluded nodes in the tree"
                              IsChecked="{Binding ShowExcludedNodesInTree}"
                              Padding="4" CornerRadius="4" Background="Transparent" />
            </Grid>

            <!-- Save / Load pinned to the bottom -->
            <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*, 4, *" Margin="0,8,0,0">
                <Button Grid.Column="0" Content="Save ▾" CornerRadius="4" HorizontalAlignment="Stretch"
                        Command="{Binding SaveChainCommand}" />
                <Button Grid.Column="2" Content="Load ▾" CornerRadius="4" HorizontalAlignment="Stretch"
                        Command="{Binding LoadChainCommand}" />
            </Grid>

            <!-- Filter cards + inline Add button, scrollable -->
            <ScrollViewer x:Name="FiltersScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical">

                    <!-- Existing filter cards -->
                    <ItemsControl x:Name="FiltersItemsControl" ItemsSource="{Binding Filters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FilterViewModel">
                                <Border BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="4"
                                        Margin="0,0,0,6" Background="#333333"
                                        Tag="{Binding}">
                                    <Grid ColumnDefinitions="Auto, *, Auto" Margin="8,7">

                                        <!-- Left: enabled checkbox -->
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0" />

                                        <!-- Centre: summary + technical description -->
                                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Summary}"
                                                       FontWeight="Medium"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11" Opacity="0.55"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!-- Right: drag handle · edit · delete -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    Spacing="2" VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                            <!-- Drag handle: PointerPressed handler set in code-behind -->
                                            <TextBlock x:Name="DragHandle"
                                                       Text="≡" Foreground="Gray"
                                                       VerticalAlignment="Center"
                                                       Cursor="Hand" Margin="0,0,4,0" />
                                            <Button Content="✎"
                                                    Width="26" Height="26" CornerRadius="4"
                                                    Padding="0"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Background="Transparent"
                                                    Foreground="#a0a0a0"
                                                    FontSize="13"
                                                    Command="{Binding $parent[UserControl].((vm:FilterChainViewModel)DataContext).RequestEditFilterCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="✕"
                                                    Command="{Binding $parent[UserControl].((vm:FilterChainViewModel)DataContext).RemoveFilterCommand}"
                                                    CommandParameter="{Binding}"
                                                    Width="26" Height="26" CornerRadius="4"
                                                    Padding="0"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource DangerForegroundBrush}" />
                                        </StackPanel>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Inline Add button — opens the flyout popup -->
                    <Panel>
                        <Button x:Name="AddFilterButton"
                                BorderBrush="#3e3e42" BorderThickness="1"
                                CornerRadius="4" Padding="8,7" Background="Transparent"
                                Cursor="Hand" Opacity="0.55"
                                HorizontalAlignment="Stretch"
                                Click="OnAddFilterButtonClick">
                            <TextBlock Text="+ Add filter" Foreground="#4facfe"
                                       FontStyle="Italic" HorizontalAlignment="Center" />
                        </Button>

                        <!-- Add-filter flyout popup -->
                        <Popup x:Name="AddFilterPopup"
                               Placement="Bottom"
                               IsLightDismissEnabled="True"
                               PlacementTarget="{Binding ElementName=AddFilterButton}">
                            <views:AddFilterFlyout x:Name="AddFilterFlyoutControl"
                                                   DataContext="{Binding AddFilter}" />
                        </Popup>
                    </Panel>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
