<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             x:Class="SmartCopy.UI.Views.FilterChainView"
             x:DataType="vm:FilterChainViewModel">
    <Border Background="#252526" BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="6" Padding="10">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                <TextBlock Text="FILTERS" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#4facfe" />
                <Button Content="+ Add ▾" CornerRadius="4" />
                <Button Content="Save ▾" CornerRadius="4" />
                <Button Content="Load ▾" CornerRadius="4" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding Filters}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,8,8" Background="#333333">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="≡" VerticalAlignment="Center" Cursor="Hand" Foreground="Gray" />
                                <TextBlock Text="{Binding Description}" VerticalAlignment="Center" />
                                <ComboBox SelectedIndex="0" Width="150" CornerRadius="4">
                                    <ComboBoxItem Content="{Binding Mode}" />
                                </ComboBox>
                                <ToggleButton IsChecked="{Binding IsEnabled}" Content="●" Width="30" Height="28" CornerRadius="4" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                                <Button Content="✕" Width="30" Height="28" CornerRadius="4" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="Transparent" Foreground="#f44336" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
