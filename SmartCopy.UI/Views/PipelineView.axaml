<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             x:Class="SmartCopy.UI.Views.PipelineView"
             x:DataType="vm:PipelineViewModel">
    <Border Background="#252526" BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="6" Padding="10">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                <TextBlock Text="PIPELINE" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#4facfe" />
                <Button Content="Copy ▾" CornerRadius="4" />
                <Button Content="Move ▾" CornerRadius="4" />
                <Button Content="Delete" CornerRadius="4" />
                <Button Content="Custom ▾" CornerRadius="4" />
                <Button Content="▶ Run" Background="#4caf50" Foreground="White" FontWeight="Bold" CornerRadius="4" />
                <Button Content="👁 Preview" CornerRadius="4" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding Steps}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Border BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,5,5" Background="#333333">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding Description}" VerticalAlignment="Center" />
                                    <Button Content="✕" Width="24" Height="24" CornerRadius="4" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="Transparent" Foreground="#f44336" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="→" VerticalAlignment="Center" Margin="5" Foreground="Gray" FontWeight="Bold" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
