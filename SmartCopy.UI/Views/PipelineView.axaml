<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             xmlns:pipelineViews="clr-namespace:SmartCopy.UI.Views.Pipeline"
             xmlns:corePipeline="clr-namespace:SmartCopy.Core.Pipeline;assembly=SmartCopy.Core"
             x:Class="SmartCopy.UI.Views.PipelineView"
             x:DataType="vm:PipelineViewModel">
    <Border Background="#252526" BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="6" Padding="10">
        <DockPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Vertical"
                        Spacing="6"
                        Width="130"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                <Button Content="{Binding RunButtonLabel}"
                        Command="{Binding RunPipelineCommand}"
                        ToolTip.Tip="{Binding BlockingValidationMessage}"
                        AutomationProperties.Name="Run pipeline"
                        Background="#4caf50" Foreground="White" FontWeight="Bold"
                        CornerRadius="4"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />
                <Button Content="👁  Preview"
                        Command="{Binding PreviewPipelineCommand}"
                        ToolTip.Tip="{Binding BlockingValidationMessage}"
                        AutomationProperties.Name="Preview pipeline"
                        CornerRadius="4"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Spacing="10"
                        Margin="0,0,0,8">
                <TextBlock Text="PIPELINE"
                           FontWeight="SemiBold"
                           Foreground="#4facfe"
                           VerticalAlignment="Center" />
            </StackPanel>

            <ScrollViewer x:Name="StepsScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="0">
                    <ListBox ItemsSource="{Binding Steps}"
                             SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             KeyDown="OnStepListKeyDown">
                        <ListBox.Styles>
                            <!-- Suppress default selection/hover highlight -->
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <!-- Focus ring on the step card border -->
                            <Style Selector="ListBoxItem:focus-visible > StackPanel > Border">
                                <Setter Property="BorderBrush" Value="#4facfe" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PipelineStepViewModel">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border BorderBrush="#3e3e42" BorderThickness="1"
                                            CornerRadius="4" Padding="10,6"
                                            Background="#333333"
                                            MinWidth="140">
                                        <Grid RowDefinitions="Auto, Auto, Auto">
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Icon}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Summary}"
                                                           FontWeight="Medium"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="2"
                                                        Content="✎"
                                                        Command="{Binding $parent[UserControl].((vm:PipelineViewModel)DataContext).RequestEditStepCommand}"
                                                        CommandParameter="{Binding}"
                                                        AutomationProperties.Name="Edit step"
                                                        Width="20" Height="20"
                                                        CornerRadius="3"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Background="Transparent"
                                                        FontSize="10"
                                                        VerticalAlignment="Top"
                                                        Margin="6,0,0,0" />
                                                <Button Grid.Column="3"
                                                        Content="✕"
                                                        Command="{Binding $parent[UserControl].((vm:PipelineViewModel)DataContext).RemoveStepCommand}"
                                                        CommandParameter="{Binding}"
                                                        AutomationProperties.Name="Remove step"
                                                        Width="20" Height="20"
                                                        CornerRadius="3"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource DangerForegroundBrush}"
                                                        FontSize="10"
                                                        VerticalAlignment="Top"
                                                        Margin="8,0,0,0" />
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                       IsVisible="{Binding HasDescription}"
                                                       Text="{Binding Description}"
                                                       FontSize="10"
                                                       Opacity="0.55"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />

                                            <StackPanel Grid.Row="2" Spacing="4" Margin="0,4,0,0">
                                                <Border IsVisible="{Binding ShowDeleteBadge}"
                                                        Background="#3b3b3b"
                                                        CornerRadius="3"
                                                        Padding="4,2">
                                                    <TextBlock Text="{Binding DeleteBadge}"
                                                               Foreground="#f0ad4e"
                                                               FontSize="10" />
                                                </Border>

                                                <TextBlock IsVisible="{Binding HasValidationError}"
                                                           Text="{Binding ValidationMessage}"
                                                           Foreground="#f0ad4e"
                                                           FontSize="10"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="→"
                                               VerticalAlignment="Center"
                                               Margin="6,0"
                                               Foreground="Gray"
                                               FontWeight="Bold"
                                               FontSize="14" />

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Panel>
                        <Button x:Name="AddStepButton"
                                BorderBrush="#3e3e42" BorderThickness="1"
                                CornerRadius="4" Padding="10,6"
                                Background="Transparent"
                                Cursor="Hand" Opacity="0.55"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Add step"
                                Click="OnAddStepButtonClick">
                            <TextBlock Text="+ Add step"
                                       Foreground="#4facfe"
                                       FontStyle="Italic" />
                        </Button>

                        <Popup x:Name="AddStepPopup"
                               Placement="TopEdgeAlignedLeft"
                               IsLightDismissEnabled="True"
                               PlacementTarget="{Binding ElementName=AddStepButton}">
                            <pipelineViews:AddStepFlyout x:Name="AddStepFlyoutControl"
                                                         DataContext="{Binding AddStep}" />
                        </Popup>
                    </Panel>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>
