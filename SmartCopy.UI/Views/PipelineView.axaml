<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             xmlns:pipelineViews="clr-namespace:SmartCopy.UI.Views.Pipeline"
             xmlns:corePipeline="clr-namespace:SmartCopy.Core.Pipeline;assembly=SmartCopy.Core"
             x:Class="SmartCopy.UI.Views.PipelineView"
             x:DataType="vm:PipelineViewModel">
    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
        <DockPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Vertical"
                        Spacing="6"
                        Width="130"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                <Button Content="{Binding RunButtonLabel}"
                        Command="{Binding RunPipelineCommand}"
                        ToolTip.Tip="{Binding BlockingValidationMessage}"
                        AutomationProperties.Name="Run pipeline"
                        Background="{DynamicResource RunButtonBackgroundBrush}" Foreground="White" FontWeight="Bold"
                        CornerRadius="4"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />
                <Button Content="👁  Preview"
                        Command="{Binding PreviewPipelineCommand}"
                        ToolTip.Tip="{Binding BlockingValidationMessage}"
                        AutomationProperties.Name="Preview pipeline"
                        CornerRadius="4"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />
                <Button Content="Save As Preset"
                        CornerRadius="4"
                        Margin="0,4,0,0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        IsVisible="{Binding HasSteps}"
                        Command="{Binding SavePipelineCommand}" />
                <Button x:Name="LoadPresetButton"
                        Content="Load Preset"
                        CornerRadius="4"
                        Margin="0,4,0,0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        IsVisible="{Binding !HasSteps}">
                    <Button.Flyout>
                        <Flyout Placement="LeftEdgeAlignedTop">
                            <StackPanel MinWidth="200" MaxHeight="300">
                                <TextBlock Text="Load Pipeline Preset" Opacity="0.5" Margin="4,0,0,8" FontSize="11" />
                                <TextBlock Text="No saved pipelines found." IsVisible="{Binding !UserPresets.Count}" Margin="4,0,0,0" Opacity="0.5" />
                                <ItemsControl ItemsSource="{Binding UserPresets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="corePipeline:PipelinePreset">
                                            <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                                <Button Grid.Column="0" 
                                                        Content="{Binding Name}" 
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Background="Transparent"
                                                        Click="OnLoadPresetButtonClick"
                                                        CommandParameter="{Binding Name}" />
                                                <Button Grid.Column="1" Content="✕"
                                                        Click="OnDeletePipelinePresetButtonClick"
                                                        CommandParameter="{Binding Name}"
                                                        Width="26" Height="26" CornerRadius="4"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Background="Transparent"
                                                        ToolTip.Tip="Delete pipeline"
                                                        Foreground="{DynamicResource DangerForegroundBrush}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Spacing="10"
                        Margin="0,0,0,8">
                <TextBlock Text="PIPELINE"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding BlockingValidationMessage}"
                           IsVisible="{Binding BlockingValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="{DynamicResource WarningForegroundBrush}"
                           FontSize="11"
                           Opacity="0.85"
                           VerticalAlignment="Center" />
            </StackPanel>

            <ScrollViewer x:Name="StepsScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="0">
                    <ListBox x:Name="StepsItemsControl"
                             ItemsSource="{Binding Steps}"
                             SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             KeyDown="OnStepListKeyDown">
                        <ListBox.Styles>
                            <!-- Suppress default selection/hover highlight -->
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                            <!-- Focus ring on the step card border -->
                            <Style Selector="ListBoxItem:focus-visible > StackPanel > Border">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Style>
                            <!-- Active step highlight: shown while this step is executing -->
                            <Style Selector="Border.activeStep">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderThickness" Value="2" />
                                <Setter Property="Background" Value="{DynamicResource AccentActiveBrush}" />
                                <Setter Property="BoxShadow" Value="0 0 10 2 #4facfe" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PipelineStepViewModel">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            ContextRequested="OnStepContextRequested">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Swap destination with source path"
                                                      Click="OnSwapWithSourceClick" />
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1"
                                            CornerRadius="4" Padding="10,6"
                                            Background="{DynamicResource ItemBackgroundBrush}"
                                            MinWidth="140"
                                            Classes.activeStep="{Binding IsActiveStep}">
                                        <Grid RowDefinitions="Auto, Auto, Auto">
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, *, Auto, Auto">
                                                <!-- Drag handle -->
                                                <TextBlock Grid.Column="0"
                                                           x:Name="DragHandle"
                                                           Text="≡" Foreground="Gray"
                                                           VerticalAlignment="Center"
                                                           Cursor="Hand" Margin="0,0,6,0" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Icon}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Label}"
                                                           FontWeight="Medium"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="3"
                                                        Content="✎"
                                                        IsVisible="{Binding IsConfigurable}"
                                                        Command="{Binding $parent[UserControl].((vm:PipelineViewModel)DataContext).RequestEditStepCommand}"
                                                        CommandParameter="{Binding}"
                                                        AutomationProperties.Name="Edit step"
                                                        Width="20" Height="20"
                                                        CornerRadius="3"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Background="Transparent"
                                                        FontSize="10"
                                                        VerticalAlignment="Top"
                                                        Margin="6,0,0,0" />
                                                <Button Grid.Column="4"
                                                        Content="✕"
                                                        Command="{Binding $parent[UserControl].((vm:PipelineViewModel)DataContext).RemoveStepCommand}"
                                                        CommandParameter="{Binding}"
                                                        AutomationProperties.Name="Remove step"
                                                        Width="20" Height="20"
                                                        CornerRadius="3"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource DangerForegroundBrush}"
                                                        FontSize="10"
                                                        VerticalAlignment="Top"
                                                        Margin="8,0,0,0" />
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                       IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                       Text="{Binding Description}"
                                                       FontSize="10"
                                                       Opacity="0.55"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />

                                            <StackPanel Grid.Row="2" Spacing="4" Margin="0,4,0,0">
                                                <Border IsVisible="{Binding ShowDeleteBadge}"
                                                        Background="{DynamicResource ItemElevatedBackgroundBrush}"
                                                        CornerRadius="3"
                                                        Padding="4,2">
                                                    <TextBlock Text="{Binding DeleteBadge}"
                                                               Foreground="{DynamicResource WarningForegroundBrush}"
                                                               FontSize="10" />
                                                </Border>

                                                <TextBlock IsVisible="{Binding HasValidationError}"
                                                           Text="{Binding ValidationMessage}"
                                                           Foreground="{DynamicResource WarningForegroundBrush}"
                                                           FontSize="10"
                                                           TextWrapping="Wrap" />

                                                <TextBlock IsVisible="{Binding HasValidationWarning}"
                                                           Text="{Binding ValidationMessage}"
                                                           Foreground="{DynamicResource WarningForegroundBrush}"
                                                           FontSize="10"
                                                           Opacity="0.75"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="→"
                                               VerticalAlignment="Center"
                                               Margin="6,0"
                                               Foreground="Gray"
                                               FontWeight="Bold"
                                               FontSize="14" />

                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Panel>
                        <Button x:Name="AddStepButton"
                                BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="10,6"
                                Background="Transparent"
                                Cursor="Hand" Opacity="0.55"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsNotRunning}"
                                AutomationProperties.Name="Add step"
                                Click="OnAddStepButtonClick">
                            <TextBlock Text="+ Add step"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontStyle="Italic" />
                        </Button>

                        <Popup x:Name="AddStepPopup"
                               Placement="TopEdgeAlignedLeft"
                               IsLightDismissEnabled="True"
                               PlacementTarget="{Binding ElementName=AddStepButton}">
                            <pipelineViews:AddStepFlyout x:Name="AddStepFlyoutControl"
                                                         DataContext="{Binding AddStep}" />
                        </Popup>
                    </Panel>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>
