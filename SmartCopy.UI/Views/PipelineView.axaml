<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             xmlns:pipelineViews="clr-namespace:SmartCopy.UI.Views.Pipeline"
             xmlns:corePipeline="clr-namespace:SmartCopy.Core.Pipeline;assembly=SmartCopy.Core"
             x:Class="SmartCopy.UI.Views.PipelineView"
             x:DataType="vm:PipelineViewModel">
    <Border Background="#252526" BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="6" Padding="10">
        <DockPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Vertical"
                        Spacing="6"
                        Width="130"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                <Button Content="{Binding RunButtonLabel}"
                        Command="{Binding RunPipelineCommand}"
                        ToolTip.Tip="{Binding BlockingValidationMessage}"
                        Background="#4caf50" Foreground="White" FontWeight="Bold"
                        CornerRadius="4"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />
                <Button Content="👁  Preview"
                        Command="{Binding PreviewPipelineCommand}"
                        ToolTip.Tip="{Binding BlockingValidationMessage}"
                        CornerRadius="4"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Spacing="10"
                        Margin="0,0,0,8">
                <TextBlock Text="PIPELINE"
                           FontWeight="SemiBold"
                           Foreground="#4facfe"
                           VerticalAlignment="Center" />

                <Button Content="Load Preset ▾" CornerRadius="4">
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                            <MenuItem Header="Standard">
                                <MenuItem ItemsSource="{Binding StandardPresets}">
                                    <MenuItem.ItemTemplate>
                                        <DataTemplate x:DataType="corePipeline:PipelinePreset">
                                            <MenuItem Header="{Binding Name}"
                                                      Command="{Binding $parent[UserControl].((vm:PipelineViewModel)DataContext).LoadPresetAsyncCommand}"
                                                      CommandParameter="{Binding Name}" />
                                        </DataTemplate>
                                    </MenuItem.ItemTemplate>
                                </MenuItem>
                            </MenuItem>

                            <Separator />

                            <MenuItem Header="My Pipelines" ItemsSource="{Binding UserPresets}">
                                <MenuItem.ItemTemplate>
                                    <DataTemplate x:DataType="corePipeline:PipelinePreset">
                                        <MenuItem Header="{Binding Name}"
                                                  Command="{Binding $parent[UserControl].((vm:PipelineViewModel)DataContext).LoadPresetAsyncCommand}"
                                                  CommandParameter="{Binding Name}" />
                                    </DataTemplate>
                                </MenuItem.ItemTemplate>
                            </MenuItem>

                            <Separator />

                            <MenuItem Header="Save current pipeline..."
                                      Command="{Binding SavePipelineAsyncCommand}" />

                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <ScrollViewer x:Name="StepsScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="0">
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PipelineStepViewModel">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border BorderBrush="#3e3e42" BorderThickness="1"
                                            CornerRadius="4" Padding="10,6"
                                            Background="#333333"
                                            MinWidth="90">
                                        <Grid RowDefinitions="Auto, Auto, Auto, Auto">
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Icon}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,6,0" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Label}"
                                                           FontWeight="Medium"
                                                           VerticalAlignment="Center" />
                                                <Button Grid.Column="2"
                                                        Content="✎"
                                                        Command="{Binding $parent[UserControl].((vm:PipelineViewModel)DataContext).RequestEditStepCommand}"
                                                        CommandParameter="{Binding}"
                                                        Width="20" Height="20"
                                                        CornerRadius="3"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Background="Transparent"
                                                        FontSize="10"
                                                        VerticalAlignment="Top"
                                                        Margin="6,0,0,0" />
                                                <Button Grid.Column="3"
                                                        Content="✕"
                                                        Command="{Binding $parent[UserControl].((vm:PipelineViewModel)DataContext).RemoveStepCommand}"
                                                        CommandParameter="{Binding}"
                                                        Width="20" Height="20"
                                                        CornerRadius="3"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Background="Transparent"
                                                        Foreground="#f44336"
                                                        FontSize="10"
                                                        VerticalAlignment="Top"
                                                        Margin="8,0,0,0" />
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Details}"
                                                       FontSize="10"
                                                       Opacity="0.55"
                                                       TextWrapping="Wrap"
                                                       Margin="0,3,0,0" />

                                            <Grid Grid.Row="2"
                                                  ColumnDefinitions="*, Auto"
                                                  IsVisible="{Binding HasDestination}"
                                                  Margin="0,4,0,0">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding DestinationPath}"
                                                         Watermark="Destination path..."
                                                         FontSize="11"
                                                         Background="#2a2a2a"
                                                         CornerRadius="3"
                                                         Padding="4,2"
                                                         MinWidth="160" />
                                                <Button Grid.Column="1"
                                                        Content="📁"
                                                        FontSize="11"
                                                        Padding="4,2"
                                                        Margin="4,0,0,0"
                                                        CornerRadius="3"
                                                        ToolTip.Tip="Browse for destination" />
                                            </Grid>

                                            <Border Grid.Row="3"
                                                    IsVisible="{Binding ShowDeleteBadge}"
                                                    Background="#3b3b3b"
                                                    CornerRadius="3"
                                                    Margin="0,4,0,0"
                                                    Padding="4,2">
                                                <TextBlock Text="{Binding DeleteBadge}"
                                                           Foreground="#f0ad4e"
                                                           FontSize="10" />
                                            </Border>

                                            <TextBlock Grid.Row="3"
                                                       IsVisible="{Binding HasValidationError}"
                                                       Text="{Binding ValidationMessage}"
                                                       Foreground="#f0ad4e"
                                                       FontSize="10"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="→"
                                               VerticalAlignment="Center"
                                               Margin="6,0"
                                               Foreground="Gray"
                                               FontWeight="Bold"
                                               FontSize="14" />

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Panel>
                        <Button x:Name="AddStepButton"
                                BorderBrush="#3e3e42" BorderThickness="1"
                                CornerRadius="4" Padding="10,6"
                                Background="Transparent"
                                Cursor="Hand" Opacity="0.55"
                                VerticalAlignment="Center"
                                Click="OnAddStepButtonClick">
                            <TextBlock Text="+ Add step"
                                       Foreground="#4facfe"
                                       FontStyle="Italic" />
                        </Button>

                        <Popup x:Name="AddStepPopup"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=AddStepButton}">
                            <pipelineViews:AddStepFlyout x:Name="AddStepFlyoutControl"
                                                         DataContext="{Binding AddStep}" />
                        </Popup>
                    </Panel>

                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>
