<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             xmlns:views="clr-namespace:SmartCopy.UI.Views"
             x:Class="SmartCopy.UI.Views.StatusBarView"
             x:DataType="vm:StatusBarViewModel">
    <DockPanel>
        <!-- Right side: exactly one of three panels is visible -->
        <Panel DockPanel.Dock="Right" IsVisible="{Binding Progress.IsActive}">
            <views:OperationProgressView DataContext="{Binding Progress}" />
        </Panel>
        <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal"
                    IsVisible="{Binding IsScanning}"
                    VerticalAlignment="Center"
                    Spacing="6"
                    Margin="0,0,8,0">
            <TextBlock Text="{Binding ScanStatusText}" VerticalAlignment="Center" />
            <Button Command="{Binding CancelScanCommand}"
                    Content="Cancel"
                    Padding="6,1"
                    VerticalAlignment="Center"
                    Background="{DynamicResource CancelButtonBackgroundBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    CornerRadius="3" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Right"
                   Text="Ready"
                   IsVisible="{Binding IsIdle}"
                   VerticalAlignment="Center" Margin="0,0,8,0"
                   Opacity="0.7" />
        <!-- Left side: always visible -->
        <views:SelectionView DataContext="{Binding Selection}" />
    </DockPanel>
</UserControl>
