<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmPipeline="clr-namespace:SmartCopy.UI.ViewModels.Pipeline"
             x:Class="SmartCopy.UI.Views.Pipeline.StepEditors.RenameStepEditor"
             x:DataType="vmPipeline:RenameStepEditorViewModel">
    <StackPanel Spacing="8">
        <TextBlock Text="Pattern" FontSize="12" Opacity="0.7" />
        <TextBox Text="{Binding Pattern, Mode=TwoWay}"
                 Watermark="{}{name}_{ext}" />

        <StackPanel Orientation="Horizontal" Spacing="6">
            <Border BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="10" Padding="6,2">
                <TextBlock Text="{}{name}" FontSize="11" />
            </Border>
            <Border BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="10" Padding="6,2">
                <TextBlock Text="{}{ext}" FontSize="11" />
            </Border>
        </StackPanel>

        <TextBlock Text="{Binding LivePreviewName}" Opacity="0.7" FontSize="11" />
    </StackPanel>
</UserControl>
