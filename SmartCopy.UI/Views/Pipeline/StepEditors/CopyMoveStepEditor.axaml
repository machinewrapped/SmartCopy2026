<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SmartCopy.UI.Views.Pipeline.StepEditors.CopyMoveStepEditor">
   <StackPanel Spacing="8">
       <TextBlock Text="Destination Path" FontSize="12" Opacity="0.7" />
       <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
           <ComboBox Grid.Column="0"
                     IsEditable="True"
                     ItemsSource="{Binding DestinationBookmarks}"
                     SelectedItem="{Binding SelectedDestinationBookmark, Mode=TwoWay}"
                     Text="{Binding DestinationPath, Mode=TwoWay}"
                     HorizontalAlignment="Stretch" />
           <Button Grid.Column="1"
                   Content="📁"
                   IsEnabled="False"
                   ToolTip.Tip="Browse (Phase 2)"
                   Width="36" />
       </Grid>
   </StackPanel>
</UserControl>
