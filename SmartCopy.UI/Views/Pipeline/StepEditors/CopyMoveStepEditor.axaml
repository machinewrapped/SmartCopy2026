<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:SmartCopy.UI.Views"
             x:Class="SmartCopy.UI.Views.Pipeline.StepEditors.CopyMoveStepEditor">
   <StackPanel Spacing="8">
       <TextBlock Text="Destination Path" FontSize="12" Opacity="0.7" />
       <views:PathPickerControl DataContext="{Binding DestinationPathPicker}"
                                BrowseDialogTitle="Select destination folder"
                                BrowseButtonToolTip="Browse for destination folder" />

       <TextBlock Text="Overwrite Mode" FontSize="12" Opacity="0.7" Margin="0,8,0,0" />
       <ComboBox ItemsSource="{Binding OverwriteModes}"
                 SelectedItem="{Binding SelectedOverwriteMode}"
                 HorizontalAlignment="Stretch">
           <ComboBox.ItemTemplate>
               <DataTemplate>
                   <TextBlock Text="{Binding}" />
               </DataTemplate>
           </ComboBox.ItemTemplate>
       </ComboBox>
   </StackPanel>
</UserControl>
