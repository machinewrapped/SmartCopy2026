<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmPipeline="clr-namespace:SmartCopy.UI.ViewModels.Pipeline"
             x:Class="SmartCopy.UI.Views.Pipeline.StepEditors.ConvertStepEditor"
             x:DataType="vmPipeline:ConvertStepEditorViewModel">
    <StackPanel Spacing="8">
        <TextBlock Text="Output Extension" FontSize="12" Opacity="0.7" />
        <TextBox Text="{Binding OutputExtension, Mode=TwoWay}" Watermark="mp3" />
    </StackPanel>
</UserControl>
