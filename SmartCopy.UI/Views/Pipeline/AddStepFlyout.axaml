<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmPipeline="clr-namespace:SmartCopy.UI.ViewModels.Pipeline"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             xmlns:corePipeline="clr-namespace:SmartCopy.Core.Pipeline;assembly=SmartCopy.Core"
             x:Class="SmartCopy.UI.Views.Pipeline.AddStepFlyout"
             x:DataType="vmPipeline:AddStepViewModel"
             MinWidth="180">
    <UserControl.DataTemplates>
        <TreeDataTemplate DataType="vmPipeline:AddStepMenuItem" ItemsSource="{Binding Items}">
            <Panel HorizontalAlignment="Stretch" MinWidth="200">
                <Grid ColumnDefinitions="*, Auto" Margin="0,1" HorizontalAlignment="Stretch" IsVisible="{Binding !IsSeparator}">
                    <TextBlock Grid.Column="0" Text="{Binding Header}" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <Button Grid.Column="1"
                            IsVisible="{Binding IsUserDefined}"
                            Content="✕" Width="28" Height="28" Padding="0"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            CornerRadius="4" Background="Transparent"
                            Foreground="{DynamicResource DangerForegroundBrush}" FontSize="12"
                            Command="{Binding DeleteCommand}"
                            CommandParameter="{Binding DeleteCommandParameter}" />
                </Grid>
                <Separator Height="1" Background="#3e3e42" Margin="-12,0" IsVisible="{Binding IsSeparator}" />
            </Panel>
        </TreeDataTemplate>
    </UserControl.DataTemplates>
    <UserControl.Styles>
        <Style Selector="MenuItem">
            <Setter Property="Command" Value="{Binding Command}" />
            <Setter Property="CommandParameter" Value="{Binding CommandParameter}" />
            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
        </Style>
        <Style Selector="MenuItem > Border:disabled">
            <Setter Property="Opacity" Value="0.5" />
        </Style>
    </UserControl.Styles>
    <Border Background="#1e1e1e" BorderBrush="#555" BorderThickness="1"
            CornerRadius="6" Padding="4">
        <Panel>
            <!-- Level 1: Category selection -->
            <StackPanel IsVisible="{Binding IsLevel1Visible}" Spacing="1">
                <Grid ColumnDefinitions="*, Auto" Margin="8,4,4,2">
                    <TextBlock Grid.Column="0"
                               Text="Add Step"
                               FontWeight="SemiBold"
                               Foreground="#4facfe"
                               VerticalAlignment="Center"
                               Margin="0,2,0,2" />
                    <Button Grid.Column="1"
                            Content="✕"
                            Command="{Binding CloseCommand}"
                            Background="Transparent"
                            Padding="6,2"
                            CornerRadius="4"
                            FontSize="12"
                            Foreground="#a0a0a0" />
                </Grid>
                <Separator Height="1" Background="#3e3e42" Margin="4,0" />

                <Button Content="Copy ▸"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4">
                    <Button.Flyout>
                        <MenuFlyout Placement="RightEdgeAlignedTop" ItemsSource="{Binding CopyMenuItems, FallbackValue={x:Null}}" />
                    </Button.Flyout>
                </Button>

                <Button Content="Move ▸"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4">
                    <Button.Flyout>
                        <MenuFlyout Placement="RightEdgeAlignedTop" ItemsSource="{Binding MoveMenuItems, FallbackValue={x:Null}}" />
                    </Button.Flyout>
                </Button>

                <Button Content="Delete ▸"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4">
                    <Button.Flyout>
                        <MenuFlyout Placement="RightEdgeAlignedTop" ItemsSource="{Binding DeleteMenuItems, FallbackValue={x:Null}}" />
                    </Button.Flyout>
                </Button>

                <Separator Height="1" Background="#3e3e42" Margin="4,4" />

                <Button Content="Path steps ▸"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4">
                    <Button.Flyout>
                        <MenuFlyout Placement="RightEdgeAlignedTop" ItemsSource="{Binding PathMenuItems, FallbackValue={x:Null}}" />
                    </Button.Flyout>
                </Button>

                <Separator Height="1" Background="#3e3e42" Margin="4,4" />

                <Button Content="Load preset ▸"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        IsVisible="{Binding !HasSteps}">
                    <Button.Flyout>
                        <MenuFlyout Placement="RightEdgeAlignedTop" ItemsSource="{Binding UserPresets, FallbackValue={x:Null}}">
                            <MenuFlyout.ItemTemplate>
                                <DataTemplate x:DataType="corePipeline:PipelinePreset">
                                    <MenuItem Click="OnPipelinePresetMenuItemClick"
                                              CommandParameter="{Binding Name}">
                                        <MenuItem.Header>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" Margin="0,0,16,0" />
                                                <Button Grid.Column="1"
                                                        Content="✕" Width="28" Height="28" Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        CornerRadius="4" Background="Transparent"
                                                        Foreground="{DynamicResource DangerForegroundBrush}" FontSize="12"
                                                        VerticalAlignment="Center"
                                                        ToolTip.Tip="Delete pipeline"
                                                        Click="OnDeletePipelineClick"
                                                        CommandParameter="{Binding Name}" />
                                            </Grid>
                                        </MenuItem.Header>
                                    </MenuItem>
                                </DataTemplate>
                            </MenuFlyout.ItemTemplate>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button Content="Save current pipeline..."
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        IsVisible="{Binding HasSteps}"
                        Command="{Binding BeginSavePipelineCommand}">
                    <Button.Foreground>
                        <SolidColorBrush Color="#4facfe" />
                    </Button.Foreground>
                </Button>
            </StackPanel>



            <!-- Level 4: Name input for saving pipeline -->
            <StackPanel IsVisible="{Binding IsSavingPipeline}" Spacing="1">
                <Grid ColumnDefinitions="Auto,*" Margin="4,4,4,2">
                    <Button Grid.Column="0"
                            Content="←"
                            Command="{Binding CancelSavePipelineCommand}"
                            Background="Transparent"
                            Padding="6,2"
                            CornerRadius="4"
                            FontSize="14" />
                    <TextBlock Grid.Column="1"
                               Margin="4,2,0,0"
                               Text="Name this pipeline"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </Grid>
                <Separator Height="1" Background="#3e3e42" Margin="4,2" />
                
                <TextBox Margin="4,6"
                         Text="{Binding NewPipelineName}"
                         Watermark="e.g. My Awesome Pipeline" />
                
                <Button Margin="4,0,4,4"
                        Content="Save"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        CornerRadius="4"
                        Background="#2d2d30"
                        Command="{Binding ConfirmSavePipelineCommand}" />
            </StackPanel>
        </Panel>
    </Border>
</UserControl>
