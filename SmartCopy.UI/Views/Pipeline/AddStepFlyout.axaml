<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmPipeline="clr-namespace:SmartCopy.UI.ViewModels.Pipeline"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             xmlns:corePipeline="clr-namespace:SmartCopy.Core.Pipeline;assembly=SmartCopy.Core"
             x:Class="SmartCopy.UI.Views.Pipeline.AddStepFlyout"
             x:DataType="vmPipeline:AddStepViewModel"
             Width="300">
    <Border Background="#1e1e1e" BorderBrush="#555" BorderThickness="1"
            CornerRadius="6" Padding="4">
        <Panel>
            <!-- Level 1: Category selection -->
            <StackPanel IsVisible="{Binding IsLevel1Visible}" Spacing="1">
                <Grid ColumnDefinitions="*, Auto" Margin="8,4,4,2">
                    <TextBlock Grid.Column="0"
                               Text="Add Step"
                               FontWeight="SemiBold"
                               Foreground="#4facfe"
                               VerticalAlignment="Center"
                               Margin="0,2,0,2" />
                    <Button Grid.Column="1"
                            Content="✕"
                            Command="{Binding CloseCommand}"
                            Background="Transparent"
                            Padding="6,2"
                            CornerRadius="4"
                            FontSize="12"
                            Foreground="#a0a0a0" />
                </Grid>
                <Separator Height="1" Background="#3e3e42" Margin="4,0" />

                <Button Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        Command="{Binding SelectTopLevelStepTypeCommand}"
                        CommandParameter="{x:Static corePipeline:StepKind.Copy}">
                    <StackPanel Orientation="Vertical" Spacing="1">
                        <TextBlock Text="Copy" FontWeight="Medium" />
                        <TextBlock Text="Copy to destination" FontSize="11" Opacity="0.55" />
                    </StackPanel>
                </Button>

                <Button Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        Command="{Binding SelectTopLevelStepTypeCommand}"
                        CommandParameter="{x:Static corePipeline:StepKind.Move}">
                    <StackPanel Orientation="Vertical" Spacing="1">
                        <TextBlock Text="Move" FontWeight="Medium" />
                        <TextBlock Text="Move to destination" FontSize="11" Opacity="0.55" />
                    </StackPanel>
                </Button>

                <Button Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        Command="{Binding SelectTopLevelStepTypeCommand}"
                        CommandParameter="{x:Static corePipeline:StepKind.Delete}">
                    <StackPanel Orientation="Vertical" Spacing="1">
                        <TextBlock Text="Delete" FontWeight="Medium" />
                        <TextBlock Text="Delete source file" FontSize="11" Opacity="0.55" />
                    </StackPanel>
                </Button>

                <Separator Height="1" Background="#3e3e42" Margin="4,4" />

                <Button Content="Path steps"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        Command="{Binding NavigateToCategoryCommand}"
                        CommandParameter="{x:Static vm:StepCategory.Path}" />

                <Separator Height="1" Background="#3e3e42" Margin="4,4" />

                <Button Content="Load preset ▸"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        IsVisible="{Binding !HasSteps}">
                    <Button.Flyout>
                        <MenuFlyout Placement="RightEdgeAlignedTop" ItemsSource="{Binding UserPresets, FallbackValue={x:Null}}">
                            <MenuFlyout.ItemTemplate>
                                <DataTemplate x:DataType="corePipeline:PipelinePreset">
                                    <MenuItem Click="OnPipelinePresetMenuItemClick"
                                              CommandParameter="{Binding Name}">
                                        <MenuItem.Header>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" Margin="0,0,16,0" />
                                                <Button Grid.Column="1"
                                                        Content="🗑" Width="28" Height="28" Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        CornerRadius="4" Background="Transparent"
                                                        Foreground="#ff6b6b" FontSize="12"
                                                        VerticalAlignment="Center"
                                                        ToolTip.Tip="Delete pipeline"
                                                        Click="OnDeletePipelineClick"
                                                        CommandParameter="{Binding Name}" />
                                            </Grid>
                                        </MenuItem.Header>
                                    </MenuItem>
                                </DataTemplate>
                            </MenuFlyout.ItemTemplate>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <Button Content="Save current pipeline..."
                        Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        IsVisible="{Binding HasSteps}"
                        Command="{Binding BeginSavePipelineCommand}">
                    <Button.Foreground>
                        <SolidColorBrush Color="#4facfe" />
                    </Button.Foreground>
                </Button>
            </StackPanel>

            <!-- Level 2: Step type selection -->
            <StackPanel IsVisible="{Binding IsLevel2VisibleOnly}" Spacing="1">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,4,4,2">
                    <Button Grid.Column="0"
                            Content="←"
                            Command="{Binding GoBackCommand}"
                            Background="Transparent"
                            Padding="6,2"
                            CornerRadius="4"
                            FontSize="14" />
                    <TextBlock Grid.Column="1"
                               Margin="4,2,0,0"
                               Text="Choose step type"
                               FontWeight="SemiBold" />
                    <Button Grid.Column="2"
                            Content="✕"
                            Command="{Binding CloseCommand}"
                            Background="Transparent"
                            Padding="6,2"
                            CornerRadius="4"
                            FontSize="12"
                            Foreground="#a0a0a0" />
                </Grid>
                <Separator Height="1" Background="#3e3e42" Margin="4,0" />

                <ItemsControl ItemsSource="{Binding StepTypeItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vmPipeline:StepTypeItem">
                            <Button Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="8,6"
                                    CornerRadius="4"
                                    Command="{Binding $parent[UserControl].((vmPipeline:AddStepViewModel)DataContext).SelectStepTypeCommand, FallbackValue={x:Null}}"
                                    CommandParameter="{Binding Kind}">
                                <StackPanel Orientation="Vertical" Spacing="1">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" />
                                    <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.55" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Level 3: Preset picker for chosen step type -->
            <StackPanel IsVisible="{Binding IsLevel3Visible}" Spacing="1">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,4,4,2">
                    <Button Grid.Column="0"
                            Content="←"
                            Command="{Binding GoBackToLevel2Command}"
                            Background="Transparent"
                            Padding="6,2"
                            CornerRadius="4"
                            FontSize="14" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedStepTypeName}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />
                    <Button Grid.Column="2"
                            Content="✕"
                            Command="{Binding CloseCommand}"
                            Background="Transparent"
                            Padding="6,2"
                            CornerRadius="4"
                            FontSize="12"
                            Foreground="#a0a0a0" />
                </Grid>
                <Separator Height="1" Background="#3e3e42" Margin="4,0" />

                <!-- ＋ New... -->
                <Button Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        Command="{Binding RequestNewStepCommand}">
                    <TextBlock Text="＋ New..." Foreground="#4facfe" />
                </Button>
                <Separator Height="1" Background="#3e3e42" Margin="4,0" />

                <!-- Recently used section -->
                <StackPanel IsVisible="{Binding HasRecentPresets}">
                    <TextBlock Text="Recently used" FontSize="11" Opacity="0.5" Margin="8,4,8,2" />
                    <ItemsControl ItemsSource="{Binding RecentPresetsForType}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vmPipeline:StepPresetItem">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Button Grid.Column="0"
                                            Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="8,5"
                                            CornerRadius="4"
                                            Command="{Binding $parent[UserControl].((vmPipeline:AddStepViewModel)DataContext).PickPresetCommand, FallbackValue={x:Null}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </Button>
                                    <Button Grid.Column="1"
                                            IsVisible="{Binding IsUserDefined}"
                                            Content="🗑" Width="28" Height="28" Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            CornerRadius="4" Background="Transparent"
                                            Foreground="#f44736" FontSize="12"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="Delete preset"
                                            Command="{Binding $parent[UserControl].((vmPipeline:AddStepViewModel)DataContext).DeletePresetCommand, FallbackValue={x:Null}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Separator Height="1" Background="#3e3e42" Margin="4,0" />
                </StackPanel>

                <!-- All presets (non-recent) -->
                <StackPanel IsVisible="{Binding HasPresets}">
                    <ItemsControl ItemsSource="{Binding PresetsForType}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vmPipeline:StepPresetItem">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Button Grid.Column="0"
                                            Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="8,5"
                                            CornerRadius="4"
                                            Command="{Binding $parent[UserControl].((vmPipeline:AddStepViewModel)DataContext).PickPresetCommand, FallbackValue={x:Null}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </Button>
                                    <Button Grid.Column="1"
                                            IsVisible="{Binding IsUserDefined}"
                                            Content="🗑" Width="28" Height="28" Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            CornerRadius="4" Background="Transparent"
                                            Foreground="#f44736" FontSize="12"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="Delete preset"
                                            Command="{Binding $parent[UserControl].((vmPipeline:AddStepViewModel)DataContext).DeletePresetCommand, FallbackValue={x:Null}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>

            <!-- Level 4: Name input for saving pipeline -->
            <StackPanel IsVisible="{Binding IsSavingPipeline}" Spacing="1">
                <Grid ColumnDefinitions="Auto,*" Margin="4,4,4,2">
                    <Button Grid.Column="0"
                            Content="←"
                            Command="{Binding CancelSavePipelineCommand}"
                            Background="Transparent"
                            Padding="6,2"
                            CornerRadius="4"
                            FontSize="14" />
                    <TextBlock Grid.Column="1"
                               Margin="4,2,0,0"
                               Text="Name this pipeline"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </Grid>
                <Separator Height="1" Background="#3e3e42" Margin="4,2" />
                
                <TextBox Margin="4,6"
                         Text="{Binding NewPipelineName}"
                         Watermark="e.g. My Awesome Pipeline" />
                
                <Button Margin="4,0,4,4"
                        Content="Save"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        CornerRadius="4"
                        Background="#2d2d30"
                        Command="{Binding ConfirmSavePipelineCommand}" />
            </StackPanel>
        </Panel>
    </Border>
</UserControl>
