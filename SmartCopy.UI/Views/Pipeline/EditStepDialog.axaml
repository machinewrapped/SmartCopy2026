<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vmPipeline="clr-namespace:SmartCopy.UI.ViewModels.Pipeline"
        xmlns:editorViews="clr-namespace:SmartCopy.UI.Views.Pipeline.StepEditors"
        x:Class="SmartCopy.UI.Views.Pipeline.EditStepDialog"
        x:DataType="vmPipeline:EditStepDialogViewModel"
        Title="{Binding Title}"
        Width="460"
        SizeToContent="Height"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <StackPanel Spacing="12" Margin="20">
        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />

        <StackPanel Spacing="4">
            <TextBlock Text="Name" FontSize="12" Opacity="0.7" />
            <TextBox Text="{Binding StepName}"
                     Watermark="Auto-generated from parameters" />
        </StackPanel>

        <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10">
            <ContentControl Content="{Binding Editor}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="vmPipeline:CopyStepEditorViewModel">
                        <editorViews:CopyMoveStepEditor />
                    </DataTemplate>
                    <DataTemplate DataType="vmPipeline:MoveStepEditorViewModel">
                        <editorViews:CopyMoveStepEditor />
                    </DataTemplate>
                    <DataTemplate DataType="vmPipeline:DeleteStepEditorViewModel">
                        <editorViews:DeleteStepEditor />
                    </DataTemplate>
                    <DataTemplate DataType="vmPipeline:FlattenStepEditorViewModel">
                        <editorViews:FlattenStepEditor />
                    </DataTemplate>
                    <DataTemplate DataType="vmPipeline:RenameStepEditorViewModel">
                        <editorViews:RenameStepEditor />
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>
        </Border>

        <CheckBox Content="Save as preset"
                  IsChecked="{Binding SaveAsPreset}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel"
                    Width="80"
                    Command="{Binding CancelCommand}"
                    IsCancel="True" />
            <Button Content="OK"
                    Width="80"
                    IsDefault="True"
                    Command="{Binding OkCommand}" />
        </StackPanel>
    </StackPanel>
</Window>
