<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels.Filters"
             xmlns:views="clr-namespace:SmartCopy.UI.Views"
             x:Class="SmartCopy.UI.Views.FilterEditors.MirrorFilterEditorView"
             x:DataType="vm:MirrorFilterEditorViewModel">
    <StackPanel Spacing="10">

        <!-- Automatic path toggle -->
        <CheckBox Content="Use pipeline destination automatically"
                  IsChecked="{Binding UseAutomaticPath}" />

        <!-- Comparison path (disabled when automatic) -->
        <StackPanel Spacing="4" IsEnabled="{Binding IsManualPath}">
            <TextBlock Text="Comparison path" FontSize="12" Opacity="0.7" />
            <views:PathPickerControl DataContext="{Binding ComparisonPathPicker}"
                                     BrowseDialogTitle="Select comparison folder"
                                     BrowseButtonToolTip="Browse for comparison folder" />
        </StackPanel>

        <!-- Compare mode -->
        <StackPanel Spacing="4">
            <TextBlock Text="Compare by" FontSize="12" Opacity="0.7" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <RadioButton Content="Name only"
                             IsChecked="{Binding CompareModeIsNameOnly}"
                             GroupName="CompareMode" />
                <RadioButton Content="Name + size"
                             IsChecked="{Binding CompareModeIsNameAndSize}"
                             GroupName="CompareMode" />
            </StackPanel>
        </StackPanel>

    </StackPanel>
</UserControl>
