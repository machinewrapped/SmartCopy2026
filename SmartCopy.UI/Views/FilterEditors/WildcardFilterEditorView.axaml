<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels.Filters"
             x:Class="SmartCopy.UI.Views.FilterEditors.WildcardFilterEditorView"
             x:DataType="vm:WildcardFilterEditorViewModel">
    <StackPanel Spacing="8">
        <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                 Watermark="e.g. *.tmp;*.bak;~*" />
        <TextBlock Text="Separate multiple patterns with ;"
                   FontSize="11" Opacity="0.5" />
    </StackPanel>
</UserControl>
