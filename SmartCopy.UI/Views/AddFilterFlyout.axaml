<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             x:Class="SmartCopy.UI.Views.AddFilterFlyout"
             x:DataType="vm:AddFilterViewModel"
             Width="280">
    <Border Background="#1e1e1e" BorderBrush="#555" BorderThickness="1"
            CornerRadius="6" Padding="4">
        <Panel>

            <!-- Level 1: Filter type selection -->
            <StackPanel IsVisible="{Binding !IsLevel2Visible}" Spacing="1">
                <TextBlock Text="Add Filter" FontWeight="SemiBold" Foreground="#4facfe"
                           Margin="8,6,8,6" />
                <Separator Height="1" Background="#3e3e42" Margin="4,0" />
                <ItemsControl ItemsSource="{Binding FilterTypes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FilterTypeItem">
                            <Button Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="8,6"
                                    CornerRadius="4"
                                    Command="{Binding $parent[UserControl].((vm:AddFilterViewModel)DataContext).SelectFilterTypeCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Orientation="Vertical" Spacing="1">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" />
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11" Opacity="0.55" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Level 2: Preset picker for selected type -->
            <StackPanel IsVisible="{Binding IsLevel2Visible}" Spacing="1">

                <!-- Header row with Back button and type name -->
                <Grid ColumnDefinitions="Auto, *" Margin="4,4,8,2">
                    <Button Grid.Column="0"
                            Content="←"
                            Command="{Binding GoBackCommand}"
                            Background="Transparent"
                            Padding="6,2"
                            CornerRadius="4"
                            FontSize="14" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedType.DisplayName}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />
                </Grid>

                <Separator Height="1" Background="#3e3e42" Margin="4,0" />

                <!-- ＋ New... -->
                <Button Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="8,6"
                        CornerRadius="4"
                        Command="{Binding RequestNewFilterCommand}">
                    <TextBlock Text="＋ New..." Foreground="#4facfe" />
                </Button>

                <Separator Height="1" Background="#3e3e42" Margin="4,0" />

                <!-- Recently used section -->
                <StackPanel IsVisible="{Binding HasRecentPresets}">
                    <TextBlock Text="Recently used" FontSize="11" Opacity="0.5"
                               Margin="8,4,8,2" />
                    <ItemsControl ItemsSource="{Binding RecentPresetsForType}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PresetItem">
                                <Button Background="Transparent"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,5"
                                        CornerRadius="4"
                                        Command="{Binding $parent[UserControl].((vm:AddFilterViewModel)DataContext).PickPresetCommand}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Separator Height="1" Background="#3e3e42" Margin="4,0" />
                </StackPanel>

                <!-- All presets (non-recent) -->
                <StackPanel IsVisible="{Binding HasPresets}">
                    <ItemsControl ItemsSource="{Binding PresetsForType}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PresetItem">
                                <Button Background="Transparent"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="8,5"
                                        CornerRadius="4"
                                        Command="{Binding $parent[UserControl].((vm:AddFilterViewModel)DataContext).PickPresetCommand}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>

        </Panel>
    </Border>
</UserControl>
