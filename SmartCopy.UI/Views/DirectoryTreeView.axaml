<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             xmlns:conv="clr-namespace:SmartCopy.UI.Converters"
             x:Class="SmartCopy.UI.Views.DirectoryTreeView"
             x:DataType="vm:DirectoryTreeViewModel">
    
    <UserControl.Resources>
        <conv:CheckStateConverter x:Key="CheckStateConverter" />
    </UserControl.Resources>

    <TreeView ItemsSource="{Binding RootNodes}"
              SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
              Background="Transparent"
              BorderThickness="0">
        <TreeView.ItemTemplate>
            <TreeDataTemplate ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <CheckBox IsChecked="{Binding CheckState, Converter={StaticResource CheckStateConverter}}" 
                              IsThreeState="True" />
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                </StackPanel>
            </TreeDataTemplate>
        </TreeView.ItemTemplate>
    </TreeView>
</UserControl>
