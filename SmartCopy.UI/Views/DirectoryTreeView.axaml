<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels"
             xmlns:conv="clr-namespace:SmartCopy.UI.Converters"
             x:Class="SmartCopy.UI.Views.DirectoryTreeView"
             x:DataType="vm:DirectoryTreeViewModel">
    
    <UserControl.Resources>
        <conv:CheckStateConverter x:Key="CheckStateConverter" />
        <conv:FilterResultOpacityConverter x:Key="FilterResultOpacityConverter" />
        <conv:NodeVisibilityConverter x:Key="NodeVisibilityConverter" />
    </UserControl.Resources>

    <TreeView ItemsSource="{Binding RootNodes}"
              SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
              Background="Transparent"
              BorderThickness="0">
        <TreeView.Styles>
            <Style Selector="TreeViewItem">
                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                <Setter Property="IsVisible">
                    <Setter.Value>
                        <MultiBinding Converter="{StaticResource NodeVisibilityConverter}">
                            <Binding Path="IsFilterIncluded" />
                            <Binding Path="DataContext.ShowFilteredNodesInTree" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                        </MultiBinding>
                    </Setter.Value>
                </Setter>
            </Style>
        </TreeView.Styles>
        <TreeView.ItemTemplate>
            <TreeDataTemplate ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal" Spacing="4"
                            Opacity="{Binding FilterResult, Converter={StaticResource FilterResultOpacityConverter}}">
                    <CheckBox IsChecked="{Binding CheckState, Converter={StaticResource CheckStateConverter}}"
                              IsEnabled="{Binding IsFilterIncluded}"
                              IsThreeState="False" />
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                </StackPanel>
            </TreeDataTemplate>
        </TreeView.ItemTemplate>
    </TreeView>
</UserControl>
