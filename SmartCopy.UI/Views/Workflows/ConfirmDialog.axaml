<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels.Workflows"
        x:Class="SmartCopy.UI.Views.Workflows.ConfirmDialog"
        x:DataType="vm:ConfirmDialogViewModel"
        Title="{Binding Title}"
        Width="360"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e">
    <StackPanel Spacing="12" Margin="20">

        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="{Binding CancelText}"
                    Command="{Binding CancelCommand}"
                    Width="80"
                    IsCancel="True" />
            <Button Content="{Binding ConfirmText}"
                    Command="{Binding ConfirmCommand}"
                    Width="80"
                    IsDefault="True" />
        </StackPanel>

    </StackPanel>
</Window>
