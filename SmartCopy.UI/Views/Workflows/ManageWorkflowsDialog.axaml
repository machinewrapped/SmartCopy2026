<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartCopy.UI.ViewModels.Workflows"
        xmlns:wf="clr-namespace:SmartCopy.Core.Workflows;assembly=SmartCopy.Core"
        x:Class="SmartCopy.UI.Views.Workflows.ManageWorkflowsDialog"
        x:DataType="vm:ManageWorkflowsDialogViewModel"
        Title="Manage Workflows"
        Width="460" Height="380"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e">
    <Grid RowDefinitions="*, Auto" Margin="16">

        <ListBox Grid.Row="0"
                 ItemsSource="{Binding Workflows}"
                 SelectedItem="{Binding SelectedWorkflow}"
                 Background="#252526"
                 CornerRadius="4">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="wf:WorkflowPreset">
                    <DockPanel Margin="4">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                            <Button Content="Rename"
                                    Click="OnRenameClick"
                                    FontSize="12"
                                    Padding="8,4" />
                            <Button Content="Delete"
                                    Click="OnDeleteClick"
                                    FontSize="12"
                                    Padding="8,4" />
                        </StackPanel>
                        <TextBlock Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="1"
                Content="Close"
                Command="{Binding CloseCommand}"
                HorizontalAlignment="Right"
                Width="80"
                Margin="0,12,0,0" />
    </Grid>
</Window>
